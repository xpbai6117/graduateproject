/* 页面整体布局 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 聊天消息区域 */
.chat-scroll {
  flex: 1;
  padding: 10px 10px 110px; 
  padding-bottom: 0px; 
  background-color: #f5f5f5;
  overflow-y: auto;
  box-sizing: border-box;
  scroll-padding-bottom: 20px; 
  margin-top: -20px;
} 

