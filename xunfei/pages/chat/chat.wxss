/* 新增顶部间距控制 */
.top-spacer {
  width: 100%;
  background-color: #0c0c0c; /* 与容器同色 */
  z-index: 1;
}
/* 消息容器 */
.message-container {
  display: flex;
  justify-content: flex-start;
  width: 100%;
  margin: 10px 0;
}

/* 消息基本样式 */
.message {
  padding: 10px 15px;
  border-radius: 18px;
  max-width: 70%;
  word-wrap: break-word;
  font-size: 16px;
  line-height: 1.4;
}

/* 用户消息样式 */
.user-message {
  background-color: #d1e7dd;
  margin-left: auto;
  border-bottom-right-radius: 4px;
}

/* AI消息样式 */
.ai-message {
  background-color: #e2eafc;
  border-bottom-left-radius: 4px;
}

/* 输入区域 */
.input-area {
  display: flex;
  /* 减少上下padding */
  padding: 10px 15px;  
  height: 100px; /* 增加高度，例如从50px增加到70px */
  background-color: rgb(255, 255, 255);
  border-top: 1px solid #eee;
  position: fixed;
  bottom: 0;
  width: 100%;
  box-sizing: border-box;
  z-index: 10;
  align-items: center;  /* 添加垂直居中 */
}

/* 输入框 */
.input-box {
  flex: 3;
  padding: 0 15px;  /* 去除上下padding，改用line-height控制垂直居中 */
  border: 1px solid #ddd;
  border-radius: 20px;
  margin-right: 10px;
  height: 40px;
  font-size: 16px;
  line-height: 40px;  /* 与高度相同确保垂直居中 */
  box-sizing: border-box;
  text-align: left;  /* 确保文字靠左 */
}

/* 占位文字样式 */
.input-box::placeholder {
  color: #999;  /* 可选：设置占位文字颜色 */
  text-align: left;  /* 确保占位文字靠左 */
  line-height: normal;  /* 重置line-height避免继承 */
  vertical-align: middle;  /* 垂直居中 */
}

/* 发送按钮 */
.send-btn {
  flex: 1;
  padding: 0;
  border: none;
  background-color: #007aff;
  color: white;
  border-radius: 20px;
  font-size: 16px;
  height: 40px;  /* 固定高度 */
  line-height: 40px;  /* 垂直居中文字 */
  min-width: 60px;  /* 最小宽度 */
}