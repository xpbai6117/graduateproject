						<view class="card-query-title">支出分类：</view>
						<view style="margin: 20rpx 0;">
							<picker range="{{zcCategoryList}}" range-key="name" mode="{{'selector'}}" value="{{item.id}}" bindchange="bindPickerChangeZc">
								<view class="picker">
									{{zcCategoryId<0?'请选择输入分类':zcCategoryList[zcCategoryId].name}}
									<image style="width: 25rpx;height: 25rpx;" src="../../static/img/lower.png"></image>
