/* pages/budget/budget.wxss */
/* pages/register/register.wxss */

.list {
  background: #fff;
  border-radius: 20rpx;
	padding: 20rpx;
	width: 500rpx;
}

.form {
  padding: 0 60rpx;
  padding-top: 120rpx;
}

.item {
  display: flex;
  align-items: center;
	height: 80rpx;
}

.item_input {
  border-bottom: 1px solid #f5f5f5;
  flex: 1;
  height: 78rpx;
  font-size: 28rpx;
}

.item_name {
	width: 200rpx;
}

.list .item:first-child {
  border: 0;
}
.sure{
  margin-top: 60rpx;
}

.book-popup-page {
  position: relative;
  overflow: auto;
  width: 100%;
  height: 100%;
  background: #ffffff;
}

.book-popup-for {
  position: relative;
  height: 8vh;
  background-color: #f36957;
  width: 90%;
  margin: 2vh auto;
  border-radius: 5%;
  filter: progid:DXImageTransform.Microsoft.Shadow(color=#e6e6e6, direction=120, strength=4);
  -moz-box-shadow: 2px 2px 10px #e6e6e6;
  -webkit-box-shadow: 2px 2px 10px #e6e6e6;
  box-shadow: 2px 2px 10px #e6e6e6;
}

.book-name {
	padding: 25rpx;
	color: #fff;
	text-align: center;
}