<!--pages/register/register.wxml-->
<view>
  <form bindsubmit="register">
    <view class="form">
      <view class="list">
        <view class="item">
          <view class="item_name">账号：</view>
          <input class="item_input" type="text" placeholder="请输入账号" name="username"/>
        </view>
      </view>
      <view class="list">
        <view class="item">
          <view class="item_name">密码：</view>
          <input class="item_input" type="password" placeholder="请输入密码" name="pwd"/>
        </view>
      </view>
      <view class="list">
        <view class="item">
          <view class="item_name">确认密码：</view>
          <input class="item_input" type="password" placeholder="请确认密码" name="pwdConfirm"/>
        </view>
      </view>
    </view>
    <view>
      <view>
        <button class="sure" form-type="submit">提交注册</button>
      </view>
    </view>
  </form> 
</view>